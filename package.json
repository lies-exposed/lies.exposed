{
  "name": "lies.exposed",
  "version": "0.5.12",
  "private": true,
  "description": "lies.exposed project monorepo",
  "repository": "git@github.com:lies.exposed/lies-exposed.git",
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "scripts": {
    "admin": "pnpm --filter 'admin'",
    "agent": "pnpm --filter 'agent'",
    "ai-bot": "pnpm --filter 'ai-bot'",
    "api": "pnpm --filter 'api'",
    "backend": "pnpm --filter '@liexp/backend'",
    "io": "pnpm --filter '@liexp/io'",
    "eslint-config": "pnpm --filter '@liexp/eslint-config'",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "core": "pnpm --filter '@liexp/core'",
    "data": "pnpm --filter 'data'",
    "worker": "pnpm --filter 'worker'",
    "deploy:setup": "./deploy/setup.sh",
    "format": "pnpm -r run format",
    "lint": "pnpm -r run lint",
    "lint:all": "eslint --cache -c eslint.config.js",
    "lint:changed": "./scripts/lint-changed.sh",
    "corepack": "corepack",
    "corepack:up": "corepack use pnpm@latest-10 && pnpm -r exec -- corepack use pnpm@latest-10",
    "packages": "pnpm --filter '@liexp/*' --filter '!@liexp/storybook' -r",
    "services:clean": "pnpm -r --filter worker --filter ai-bot --filter api --filter web --filter admin --filter agent run clean",
    "post-deploy": "./deploy/post-deploy.sh",
    "shared": "pnpm --filter '@liexp/shared'",
    "storybook": "pnpm --filter '@liexp/storybook'",
    "test": "pnpm --filter '@liexp/test'",
    "ui": "pnpm --filter '@liexp/ui'",
    "web": "pnpm --filter 'web'",
    "vitest": "vitest",
    "vitest:expected-cov": "vitest run --coverage.enabled --coverage.thresholds.lines=90 --coverage.thresholds.functions=90 --coverage.thresholds.statements=90",
    "vitest:cov": "vitest run --coverage.enabled",
    "vitest:changed": "vitest --changed=HEAD^1",
    "knip": "VITE_VALIDATE_ENV=false knip"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "corepack": "^0.34.5",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "knip": "^5.87.0",
    "lint-staged": "^16.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">= 24",
    "npm": "please use pnpm >= 10",
    "pnpm": ">= 9",
    "yarn": "please use pnpm >= 10"
  },
  "resolutions": {
    "minimist": "^1.2.8",
    "react-dnd": "^15",
    "react-dnd-html5-backend": "^15",
    "wink-nlp": "^2.3.0",
    "@ts-endpoint/core": "file:patches/ts-endpoint-core-0.1.0.tgz",
    "@ts-endpoint/http-client": "file:patches/ts-endpoint-http-client-0.1.0.tgz",
    "@ts-endpoint/resource-client": "file:patches/ts-endpoint-resource-client-0.1.0.tgz",
    "@ts-endpoint/express": "file:patches/ts-endpoint-express-0.1.0.tgz",
    "@ts-endpoint/react-admin": "file:patches/ts-endpoint-react-admin-0.1.0.tgz",
    "@ts-endpoint/tanstack-query": "file:patches/ts-endpoint-tanstack-query-0.1.0.tgz"
  },
  "pnpm": {
    "overrides": {
      "react-is": "^18",
      "zod": "^4.3.5",
      "dotenv": "^17.3.1"
    }
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
