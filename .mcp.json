{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "api-liexp-dev-db": {
      "type":"stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://liexp:liexp-password@localhost:8432/liexp"
      ]
    },
    "playwright": {
      "type":"stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "basic-memory": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp",
        "--project",
        "lies-exposed"
      ]
    }
  }
}
