{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "rootDir": "./src",
    "tsBuildInfoFile": "lib/.build.tsbuildinfo",
    "paths": {
      "*": ["./src/*"]
    }
  },
  "include": ["./src", "!src/**/*.spec.ts"],
  "exclude": ["node_modules", "lib", "src/**/*.spec.ts", "test"]
}
