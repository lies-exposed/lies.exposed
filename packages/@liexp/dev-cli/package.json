{
  "name": "@liexp/dev-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "liexp": "./src/run.tsx"
  },
  "scripts": {
    "start": "tsx src/run.tsx",
    "build": "tsc -b tsconfig.build.json",
    "watch": "tsc -b tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache src",
    "lint-staged": "eslint --cache --fix"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@types/node": "^24.10.9",
    "@types/react": "^18.0.0",
    "eslint": "^10.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.35.0"
  }
}
