{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "typeRoots": [
      "./typings",
      "../../../node_modules/@types"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "rootDir": "./src",
    "tsBuildInfoFile": "lib/.build.tsbuildinfo",
    "paths": {
      "*": [
        "./src/*"
      ],
    }
  },
  "include": [
    "./src",
    "!src/**/*.spec.ts",
    "./typings"
  ],
  "exclude": [
    "node_modules",
    "lib",
    "src/**/*.spec.ts",
    "test"
  ]
}