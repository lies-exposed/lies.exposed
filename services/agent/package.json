{
  "name": "agent",
  "version": "0.5.12",
  "private": true,
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "imports": {
    "#cli/*": "./build/cli/*",
    "#context/*": "./build/context/*",
    "#flows/*": "./build/flows/*",
    "#io/*": "./build/io/*",
    "#providers/*": "./build/providers/*",
    "#routes/*": "./build/routes/*",
    "#tools/*": "./build/tools/*"
  },
  "files": [
    "build",
    "AGENTS.md",
    "RESEARCHER.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf build",
    "cli": "node build/cli/cli.js",
    "cli:dev": "node src/cli/cli.ts",
    "dev": "tsx --watch src/run.ts",
    "docker:dev": "node --watch build/run.js",
    "lint": "eslint --cache src",
    "start": "node build/run.js",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage --project agent-spec",
    "test:spec": "vitest --project agent-spec",
    "test:e2e": "vitest --project agent-e2e",
    "watch": "tsc -b ./tsconfig.build.json --watch",
    "watch:dev": "tsc -b --watch"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.3.1",
    "@langchain/xai": "^1.3.11",
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@ts-endpoint/core": "file:patches/ts-endpoint-core-0.1.0.tgz",
    "@ts-endpoint/express": "file:patches/ts-endpoint-express-0.1.0.tgz",
    "@ts-endpoint/resource-client": "file:patches/ts-endpoint-resource-client-0.1.0.tgz",
    "axios": "^1.13.6",
    "brave-search": "^0.9.0",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "effect": "^3.20.0",
    "express": "^5.2.1",
    "fp-ts": "^2.16.10",
    "langchain": "^1.2.37",
    "prompts": "^2.4.2",
    "puppeteer-core": "^24.38.0",
    "puppeteer-extra": "^3.3.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@types/cors": "^2.8.18",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "msw": "^2.12.10",
    "supertest": "^7.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
