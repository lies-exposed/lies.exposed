{
  "name": "agent",
  "version": "0.5.13",
  "private": true,
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "imports": {
    "#cli/*": "./build/cli/*",
    "#context/*": "./build/context/*",
    "#flows/*": "./build/flows/*",
    "#io/*": "./build/io/*",
    "#providers/*": "./build/providers/*",
    "#routes/*": "./build/routes/*",
    "#tools/*": "./build/tools/*"
  },
  "files": [
    "build",
    "AGENTS.md",
    "RESEARCHER.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf build",
    "cli": "node build/cli/cli.js",
    "cli:dev": "node src/cli/cli.ts",
    "dev": "tsx --watch src/run.ts",
    "docker:dev": "node --watch build/run.js",
    "lint": "eslint --cache src",
    "start": "node build/run.js",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage --project agent-spec",
    "test:spec": "vitest --project agent-spec",
    "test:e2e": "vitest --project agent-e2e",
    "test:eval": "DEBUG='@liexp:*' vitest --config vitest.config.eval.ts --run",
    "test:eval:record": "DEBUG_EVAL=1 DEBUG='@liexp:*' vitest --config vitest.config.eval.ts --run",
    "test:eval:replay": "REPLAY_EVAL=1 vitest --config vitest.config.eval.ts --run",
    "watch": "tsc -b ./tsconfig.build.json --watch",
    "watch:dev": "tsc -b --watch"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.4",
    "@langchain/xai": "^1.3.16",
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@ts-endpoint/core": "file:patches/ts-endpoint-core-0.1.0.tgz",
    "@ts-endpoint/express": "file:patches/ts-endpoint-express-0.1.0.tgz",
    "@ts-endpoint/resource-client": "file:patches/ts-endpoint-resource-client-0.1.0.tgz",
    "axios": "^1.15.2",
    "brave-search": "^0.9.0",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "effect": "^3.21.2",
    "express": "^5.2.1",
    "fp-ts": "^2.16.10",
    "langchain": "^1.3.3",
    "prompts": "^2.4.2",
    "puppeteer-core": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@types/cors": "^2.8.18",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "msw": "^2.13.4",
    "supertest": "^7.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
