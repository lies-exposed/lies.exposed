{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "paths": {
      "*": ["./src/*"],
      "#context/*": ["./src/context/*"],
      "#flows/*": ["./src/flows/*"],
      "#io/*": ["./src/io/*"],
      "#routes/*": ["./src/routes/*"],
      "#cli/*": ["./src/cli/*"],
      "#tools/*": ["./src/tools/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "build"],
  "references": [
    { "path": "../../packages/@liexp/eslint-config" },
    { "path": "../../packages/@liexp/core" },
    { "path": "../../packages/@liexp/io" },
    { "path": "../../packages/@liexp/shared" }
  ]
}