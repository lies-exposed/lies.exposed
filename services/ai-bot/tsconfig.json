{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "./build",
    "rootDir": "./",
    "lib": ["DOM", "ESNext"],
    "tsBuildInfoFile": "build/.tsbuildinfo",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "types": ["../../node_modules/vitest/globals"],
    "paths": {
      "*": ["./src"],
      "#common/*": ["./src/common/*"],
      "#flows/*": ["./src/flows/*"],
      "#services/*": ["./src/services/*"]
    }
  },
  "include": ["./src", "./typings", "./scripts", "./test"],
  "exclude": ["**/build", "**/lib"],
  "references": [
    { "path": "../../packages/@liexp/eslint-config" },
    { "path": "../../packages/@liexp/core" },
    { "path": "../../packages/@liexp/io" },
    { "path": "../../packages/@liexp/shared" },
    { "path": "../../packages/@liexp/backend" }
  ]
}
