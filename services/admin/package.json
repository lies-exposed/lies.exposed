{
  "name": "admin",
  "version": "0.5.12",
  "private": true,
  "type": "module",
  "files": [
    "build",
    "public"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "build:app": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app-server": "pnpm build:app && pnpm build:server",
    "clean": "rm -rf build",
    "dev": "vite dev",
    "dev:server": "tsx watch src/server/server.tsx",
    "docker:dev": "tsx --tsconfig tsconfig.server.json --watch-path=./src ./src/server/server.tsx",
    "lint": "eslint --cache src",
    "serve": "node build/server/server.js",
    "start": "vite start",
    "test": "vitest",
    "test:spec": "vitest --project admin-spec",
    "test:coverage": "vitest --run --coverage --project admin-spec",
    "test:e2e": "vitest --project e2e",
    "watch": "tsc -b --watch"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@liexp/ui": "workspace:*",
    "@sentry/react": "^10.43.0",
    "@tanstack/react-query": "^5.96.0",
    "@testing-library/react": "^16.3.2",
    "@ts-endpoint/react-admin": "file:patches/ts-endpoint-react-admin-0.1.0.tgz",
    "@ts-endpoint/resource-client": "file:patches/ts-endpoint-resource-client-0.1.0.tgz",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "effect": "^3.20.0",
    "express": "^5.2.1",
    "fp-ts": "^2.16.10",
    "openai": "^6.25.0",
    "qs": "^6.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.2",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.6",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "jsdom": "^27.4.0",
    "msw": "^2.12.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-optimizer": "^1.4.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vitest-mock-extended": "^3.1.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
