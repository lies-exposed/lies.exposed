{
  "name": "admin",
  "version": "0.5.20",
  "private": true,
  "type": "module",
  "files": [
    "build",
    "public"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "build:app": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app-server": "pnpm build:app && pnpm build:server",
    "clean": "rm -rf build",
    "dev": "vite dev",
    "dev:server": "tsx watch src/server/server.tsx",
    "docker:dev": "tsx --tsconfig tsconfig.server.json --watch-path=./src ./src/server/server.tsx",
    "lint": "eslint --cache src",
    "serve": "node build/server/server.js",
    "start": "vite start",
    "test": "vitest",
    "test:spec": "vitest --project admin-spec",
    "test:coverage": "vitest --run --coverage --project admin-spec",
    "test:e2e": "vitest --project e2e",
    "watch": "tsc -b --watch"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@liexp/ui": "workspace:*",
    "@sentry/react": "^10.65.0",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/react": "^16.3.2",
    "@ts-endpoint/react-admin": "file:patches/ts-endpoint-react-admin-0.1.0.tgz",
    "@ts-endpoint/resource-client": "file:patches/ts-endpoint-resource-client-0.1.0.tgz",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "effect": "^3.21.3",
    "express": "^5.2.1",
    "fp-ts": "^2.16.10",
    "openai": "^6.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.14.2",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.6",
    "@types/supertest": "^7.2.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^8.1.5",
    "vite-plugin-css-injected-by-js": "^5.0.2",
    "vite-plugin-optimizer": "^1.4.3",
    "vitest": "^4.1.10",
    "vitest-mock-extended": "^5.1.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
