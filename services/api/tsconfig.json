{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./build",
    "jsx": "react-jsx",
    "rootDir": "./",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "tsBuildInfoFile": "build/.tsbuildinfo",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "../../node_modules/@types",
      "../../packages/@liexp/shared/typings",
      "../../packages/@liexp/backend/typings"
    ]
  },
  "include": [
    "./src",
    "./scripts",
    "./test",
    "../../packages/@liexp/backend/typings/**/*.d.ts",
    "../../packages/@liexp/shared/typings/**/*.d.ts"
  ],
  "exclude": [
    "**/build",
    "**/lib"
  ],
  "references": [
    {
      "path": "../../packages/@liexp/eslint-config"
    },
    {
      "path": "../../packages/@liexp/core"
    },
    {
      "path": "../../packages/@liexp/io"
    },
    {
      "path": "../../packages/@liexp/shared"
    },
    {
      "path": "../../packages/@liexp/backend"
    }
  ]
}
