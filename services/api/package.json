{
  "name": "api",
  "version": "0.5.13",
  "private": true,
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "imports": {
    "#app/*": "./build/app/*",
    "#context/*": "./build/context/*",
    "#flows/*": "./build/flows/*",
    "#io/*": "./build/io/*",
    "#jobs/*": "./build/jobs/*",
    "#providers/*": "./build/providers/*",
    "#queries/*": "./build/queries/*",
    "#routes/*": "./build/routes/*",
    "#services/*": "./build/services/*",
    "#types/*": "./build/types/*",
    "#utils/*": "./build/utils/*"
  },
  "files": [
    "assets",
    "build",
    "bin",
    "config",
    "ormconfig.js"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf build deploy",
    "db:diagram": "node -r tsx/cjs -T ./node_modules/.bin/typeorm-uml ormconfig.js -D LR -d ./data/media/docs/diagrams/typeorm-uml.png",
    "db:dump": "tsx ./src/scripts/database.dump.ts",
    "db:dump:alpha": "DOTENV_CONFIG_PATH=.env.prod pnpm db:dump -p alpha",
    "generate-service-token": "tsx ./src/bin/generate-service-token.ts",
    "dev": "node --watch build/run.js",
    "dev:alpha": "DOTENV_CONFIG_PATH=.env.prod pnpm dev",
    "docker:dev": "pnpm dev",
    "lint": "eslint --cache src",
    "migration:gen": "pnpm typeorm-ts migration:generate -d ./ormconfig.js",
    "migration:revert": "pnpm typeorm-ts migration:revert -d ./ormconfig.js",
    "migration:run": "pnpm typeorm-ts migration:run -d ./ormconfig.js",
    "migration:show": "pnpm typeorm-ts migration:show -d ./ormconfig.js",
    "schema:log": "pnpm typeorm-ts schema:log -d ./ormconfig.js",
    "start": "node build/run.js",
    "start:worker": "node build/worker/index.js",
    "test": "pnpm vitest",
    "test:all": "pnpm test:spec --run && pnpm test:e2e --run",
    "test:e2e": "vitest --project api-e2e",
    "test:spec": "vitest --project api-spec",
    "tsx:build": "tsx --tsconfig tsconfig.build.json",
    "typeorm-ts": "TSX_TSCONFIG_PATH=tsconfig.build.json node --require tsx/cjs --require dotenv/config ../../node_modules/.bin/typeorm",
    "watch": "tsc -b ./tsconfig.build.json --watch",
    "watch:dev": "tsc -b --watch"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ts-endpoint/core": "file:patches/ts-endpoint-core-0.1.0.tgz",
    "@ts-endpoint/express": "file:patches/ts-endpoint-express-0.1.0.tgz",
    "axios": "^1.15.2",
    "body-parser": "^2.2.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "debug": "^4.4.0",
    "effect": "^3.21.1",
    "exifreader": "^4.38.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "express-unless": "^2.1.3",
    "fp-ts": "^2.16.10",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "page-metadata-parser": "^1.1.4",
    "pg": "^8.20.0",
    "qs": "^6.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@types/cors": "^2.8.18",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.6",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.2.1",
    "fast-check": "^3.23.2",
    "supertest": "^7.2.2",
    "typeorm-pglite": "^0.3.4",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0",
    "wink-nlp": "^2.3.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
