{
  "name": "@liexp/storybook",
  "version": "0.5.20",
  "private": true,
  "repository": "git@github.com:ascariandrea/econnessione.git",
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "typecheck": "tsc -b tsconfig.build.json --noEmit",
    "build": "tsc -b tsconfig.build.json",
    "build:app": "storybook build -o build",
    "clean": "rm -rf build && rm -rf node_modules/.cache/storybook",
    "dev": "storybook dev -p 6006 --host storybook.liexp.dev",
    "lint": "eslint --cache",
    "sb": "storybook",
    "test": "echo 'No tests configured for storybook'"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@liexp/test": "workspace:*",
    "@liexp/ui": "workspace:*",
    "@mui/material": "^7.3.9",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-links": "^10.5.0",
    "@storybook/builder-vite": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tanstack/react-query": "^5.101.2",
    "@ts-endpoint/react-admin": "file:patches/ts-endpoint-react-admin-0.1.0.tgz",
    "@visx/gradient": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "axios": "^1.16.0",
    "d3": "^7.9.0",
    "date-fns": "^4.4.0",
    "effect": "^3.21.3",
    "fast-check": "^3.23.2",
    "fp-ts": "^2.16.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.5.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.27",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-plugin-storybook": "^10.5.0",
    "prettier": "^3.9.5",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
