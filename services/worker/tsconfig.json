{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./build",
    "rootDir": "./",
    "lib": ["DOM", "ESNext"],
    "tsBuildInfoFile": "build/.tsbuildinfo",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "allowSyntheticDefaultImports": true,
    "types": ["../../node_modules/vitest/globals"],
    "paths": {
      "*": ["./src/*"],
      "#context/*": ["./src/context/*"],
      "#flows/*": ["./src/flows/*"],
      "#io/*": ["./src/io/*"],
      "#jobs/*": ["./src/jobs/*"],
      "#providers/*": ["./src/providers/*"],
      "#services/*": ["./src/services/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": [
    "./src",
    "./typings",
    "../../packages/@liexp/shared/typings",
    "../../packages/@liexp/backend/typings",
    "./scripts",
    "./test"
  ],
  "exclude": ["**/build", "**/lib"],
  "references": [
    { "path": "../../packages/@liexp/eslint-config" },
    { "path": "../../packages/@liexp/core" },
    { "path": "../../packages/@liexp/io" },
    { "path": "../../packages/@liexp/shared" },
    { "path": "../../packages/@liexp/backend" }
  ]
}
