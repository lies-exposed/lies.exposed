{
  "name": "worker",
  "version": "0.5.18",
  "private": true,
  "license": "MIT",
  "author": "Andrea Ascari <dev.ascariandrea@gmail.com>",
  "type": "module",
  "imports": {
    "#context/*": "./build/context/*",
    "#flows/*": "./build/flows/*",
    "#jobs/*": "./build/jobs/*",
    "#io/*": "./build/io/*",
    "#providers/*": "./build/providers/*",
    "#services/*": "./build/services/*",
    "#utils/*": "./build/utils/*"
  },
  "files": [
    "assets",
    "build",
    "bin",
    "config"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsgo -b tsconfig.build.json",
    "clean": "rm -rf build",
    "dev": "node --watch build/run.js",
    "docker:dev": "node --watch build/run.js",
    "lint": "eslint --cache src",
    "bin:run": "node ./build/bin/cli.js",
    "bin:generate-thumbnails": "node ./build/bin/cli.js generate-missing-thumbnails",
    "bin:upsert-nlp-entities": "node ./build/bin/cli.js upsert-nlp-entities",
    "start": "node build/run.js",
    "test": "vitest",
    "test:e2e": "vitest --project worker-e2e",
    "tsx:build": "tsx --tsconfig tsconfig.build.json",
    "watch": "tsgo -b ./tsconfig.build.json --watch",
    "watch:dev": "tsgo -b --watch",
    "pkg": "./scripts/pkg.sh"
  },
  "lint-staged": {
    "src/**/*.(ts|tsx|js|jsx)": "eslint --cache --fix"
  },
  "dependencies": {
    "@liexp/backend": "workspace:*",
    "@liexp/core": "workspace:*",
    "@liexp/io": "workspace:*",
    "@liexp/shared": "workspace:*",
    "@ts-endpoint/core": "file:patches/ts-endpoint-core-0.1.0.tgz",
    "axios": "^1.16.0",
    "cronstrue": "^3.14.0",
    "debug": "^4.4.0",
    "effect": "^3.21.3",
    "exifreader": "^4.41.0",
    "fluent-ffmpeg": "^2.1.2",
    "fp-ts": "^2.16.10",
    "instagram-private-api": "^1.46.1",
    "ioredis": "^5.10.1",
    "lodash": "^4.18.1",
    "node-cron": "^4.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "page-metadata-parser": "^1.1.4",
    "parse2-kmz": "^1.0.7",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.21.0",
    "prompts": "^2.4.2",
    "puppeteer-core": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.29",
    "wink-eng-lite-web-model": "^1.8.0",
    "wink-nlp": "^2.3.0",
    "wink-nlp-utils": "^2.1.0"
  },
  "devDependencies": {
    "@liexp/eslint-config": "workspace:*",
    "@liexp/test": "workspace:*",
    "@types/debug": "^4.1.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/lodash": "^4.17.24",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/prompts": "^2.4.9",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
